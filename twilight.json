{
  "version": "1.0.0",
  "theme_name": "Atelier Noir",
  "repo_url": "https://github.com/YOUR_GITHUB_USERNAME/atelier-noir-theme",
  "support_url": "https://github.com/YOUR_GITHUB_USERNAME/atelier-noir-theme/issues",
  "description": "ثيم فخم لمتاجر الأزياء والإكسسوارات والعطور، مع بنرات وفيديوهات قابلة للتحكم الكامل من لوحة تحكم سلة",

  "settings": [
    {
      "type": "section",
      "label": "الهوية والألوان",
      "name": "brand_colors",
      "fields": [
        { "id": "color_primary", "type": "color", "label": "اللون الأساسي (الذهبي/الفخم)", "default": "#B08D57" },
        { "id": "color_dark", "type": "color", "label": "اللون الداكن الأساسي", "default": "#151515" },
        { "id": "color_cream", "type": "color", "label": "لون الخلفية الفاتحة", "default": "#F5F1EA" }
      ]
    },
    {
      "type": "section",
      "label": "الهيرو الرئيسي (صورة الغلاف)",
      "name": "hero_section",
      "fields": [
        { "id": "hero_image", "type": "image", "label": "صورة الهيرو الرئيسية" },
        { "id": "hero_title", "type": "text", "label": "العنوان الرئيسي", "default": "فخامة لا تُقاس بالوقت" },
        { "id": "hero_subtitle", "type": "textarea", "label": "العنوان الفرعي", "default": "تشكيلة حصرية من الأزياء والعطور والإكسسوارات" },
        { "id": "hero_button_text", "type": "text", "label": "نص الزر", "default": "اكتشف التشكيلة" },
        { "id": "hero_button_url", "type": "text", "label": "رابط الزر", "default": "/collections/all" }
      ]
    },
    {
      "type": "section",
      "label": "البنرات المتحركة",
      "name": "banners_section",
      "fields": [
        { "id": "banners_enabled", "type": "checkbox", "label": "تفعيل شريط البنرات المتحركة", "default": true },
        { "id": "banner_1_image", "type": "image", "label": "بنر 1 - صورة (يفضّل 1600×600px)" },
        { "id": "banner_1_title", "type": "text", "label": "بنر 1 - عنوان", "default": "تشكيلة العطور الجديدة" },
        { "id": "banner_1_url", "type": "text", "label": "بنر 1 - رابط عند الضغط", "default": "/collections/perfumes" }
      ]
    }
  ],

  "features": [
    "component-store-features"
  ],

  "components": [
    { "name": "Hero Video Banner", "path": "home.hero-video", "icon": "video" },
    { "name": "Animated Banners Strip", "path": "home.animated-banners", "icon": "image" }
  ]
}
