{% extends "layouts.master" %}

{% block content %}
<section class="thank-you section">
    <div class="thank-you__content reveal">
        <div class="thank-you__icon">✓</div>
        <span class="section-eyebrow">تم الطلب بنجاح</span>
        <h1 class="section-title">شكرًا لك، {{ customer.first_name }}</h1>
        <p class="thank-you__message">
            استلمنا طلبك رقم <strong>#{{ order.reference_id }}</strong> وجاري تجهيزه بكل عناية.
            ستصلك رسالة تأكيد على بريدك الإلكتروني بجميع التفاصيل.
        </p>

        <div class="thank-you__order-summary">
            <div class="thank-you__row">
                <span>رقم الطلب</span>
                <span>#{{ order.reference_id }}</span>
            </div>
            <div class="thank-you__row">
                <span>الإجمالي</span>
                <span>{{ order.total }}</span>
            </div>
            <div class="thank-you__row">
                <span>طريقة الدفع</span>
                <span>{{ order.payment_method }}</span>
            </div>
        </div>

        <div class="thank-you__actions">
            <a href="{{ order.tracking_url }}" class="btn-luxury btn-luxury--dark">تتبع الطلب</a>
            <a href="/" class="btn-luxury">متابعة التسوق</a>
        </div>
    </div>
</section>

<style>
.thank-you__content {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
}
.thank-you__icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    margin: 0 auto 1.5rem;
}
.thank-you__message {
    color: var(--color-text-muted);
    line-height: 1.9;
    margin-bottom: 2.5rem;
}
.thank-you__order-summary {
    background: var(--color-cream);
    padding: 1.5rem 2rem;
    margin-bottom: 2rem;
    text-align: start;
}
.thank-you__row {
    display: flex;
    justify-content: space-between;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.95rem;
}
.thank-you__row:last-child { border-bottom: none; }
.thank-you__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
}
</style>
{% endblock %}
