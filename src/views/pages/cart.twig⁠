{% extends "layouts.master" %}

{% block content %}
<section class="cart-page section">
    <div class="section-header" style="text-align:center">
        <span class="section-eyebrow">سلة المشتريات</span>
        <h1 class="section-title">{{ cart.items|length }} قطعة في سلتك</h1>
        <hr class="section-divider">
    </div>

    {% if cart.items|length > 0 %}
    <div class="cart-page__grid">
        <div class="cart-page__items">
            {% for item in cart.items %}
            <div class="cart-item reveal">
                <div class="cart-item__image">
                    <img src="{{ item.product.image.url }}" alt="{{ item.product.name }}">
                </div>
                <div class="cart-item__details">
                    <h3 class="cart-item__name">{{ item.product.name }}</h3>
                    {% if item.options %}
                        <p class="cart-item__options">
                            {% for option in item.options %}{{ option.name }}: {{ option.value }}{% if not loop.last %} · {% endif %}{% endfor %}
                        </p>
                    {% endif %}
                    <div class="cart-item__row">
                        <div class="quantity-input quantity-input--sm">
                            <button type="button" class="quantity-input__btn" data-action="decrease" data-item-id="{{ item.id }}">−</button>
                            <input type="number" value="{{ item.quantity }}" min="1" class="quantity-input__field">
                            <button type="button" class="quantity-input__btn" data-action="increase" data-item-id="{{ item.id }}">+</button>
                        </div>
                        <span class="cart-item__price">{{ item.total }}</span>
                        <button class="cart-item__remove" data-item-id="{{ item.id }}" aria-label="حذف من السلة">✕</button>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        <aside class="cart-page__summary reveal">
            <h2 class="cart-summary__title">ملخص الطلب</h2>
            <div class="cart-summary__row">
                <span>المجموع الفرعي</span>
                <span>{{ cart.sub_total }}</span>
            </div>
            {% if cart.discount %}
            <div class="cart-summary__row cart-summary__row--discount">
                <span>الخصم</span>
                <span>−{{ cart.discount }}</span>
            </div>
            {% endif %}
            <div class="cart-summary__row cart-summary__row--total">
                <span>الإجمالي</span>
                <span>{{ cart.total }}</span>
            </div>

            <form class="cart-summary__coupon">
                <input type="text" placeholder="كود الخصم" class="cart-summary__coupon-input">
                <button type="submit" class="btn-luxury btn-luxury--dark">تطبيق</button>
            </form>

            <a href="/checkout" class="btn-luxury btn-luxury--dark cart-summary__checkout">
                إتمام الشراء
            </a>

            <p class="cart-summary__note">الدفع الآمن مضمون · إمكانية الإرجاع خلال 14 يوم</p>
        </aside>
    </div>
    {% else %}
    <div class="cart-page__empty">
        <p>سلتك فارغة حاليًا</p>
        <a href="/" class="btn-luxury btn-luxury--dark">تصفح التشكيلة</a>
    </div>
    {% endif %}
</section>

<style>
.cart-page__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 3rem;
    align-items: start;
}
@media (max-width: 900px) {
    .cart-page__grid { grid-template-columns: 1fr; }
}
.cart-item {
    display: flex;
    gap: 1.25rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
}
.cart-item__image {
    width: 96px;
    height: 120px;
    flex-shrink: 0;
    overflow: hidden;
    background: var(--color-cream);
}
.cart-item__image img { width: 100%; height: 100%; object-fit: cover; }
.cart-item__name { margin: 0 0 0.4rem; font-size: 1.05rem; }
.cart-item__options { color: var(--color-text-muted); font-size: 0.85rem; margin: 0 0 0.75rem; }
.cart-item__row { display: flex; align-items: center; gap: 1rem; }
.cart-item__price { font-family: var(--font-heading); color: var(--color-primary); margin-inline-start: auto; }
.cart-item__remove { background: none; border: none; cursor: pointer; color: var(--color-text-muted); font-size: 1rem; }
.quantity-input--sm .quantity-input__btn { width: 32px; height: 36px; }
.quantity-input--sm .quantity-input__field { width: 36px; height: 36px; }

.cart-page__summary {
    background: var(--color-dark);
    color: var(--color-cream);
    padding: 2rem;
}
.cart-summary__title { font-size: 1.3rem; margin-bottom: 1.5rem; color: var(--color-cream); }
.cart-summary__row { display: flex; justify-content: space-between; padding: 0.6rem 0; font-size: 0.95rem; }
.cart-summary__row--discount { color: var(--color-primary); }
.cart-summary__row--total {
    border-top: 1px solid rgba(245,241,234,0.15);
    margin-top: 0.5rem;
    padding-top: 1rem;
    font-family: var(--font-heading);
    font-size: 1.2rem;
}
.cart-summary__coupon { display: flex; gap: 0.5rem; margin: 1.5rem 0; }
.cart-summary__coupon-input {
    flex: 1;
    background: transparent;
    border: 1px solid rgba(245,241,234,0.25);
    color: var(--color-cream);
    padding: 0.7rem 1rem;
}
.cart-summary__checkout { display: block; text-align: center; width: 100%; margin-top: 1rem; }
.cart-summary__note { font-size: 0.78rem; color: rgba(245,241,234,0.6); text-align: center; margin-top: 1.25rem; }

.cart-page__empty { text-align: center; padding: 4rem 0; }
.cart-page__empty p { margin-bottom: 1.5rem; color: var(--color-text-muted); }
</style>
{% endblock %}
