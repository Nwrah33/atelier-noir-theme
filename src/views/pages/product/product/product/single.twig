{% extends "layouts.master" %}

{% block content %}
<section class="product-single section">
    <div class="product-single__grid">

        {# ===== Gallery ===== #}
        <div class="product-single__gallery reveal">
            <div class="product-single__main-image">
                <img src="{{ product.image.url }}" alt="{{ product.name }}" id="product-main-image">
            </div>
            {% if product.images|length > 1 %}
            <div class="product-single__thumbs">
                {% for image in product.images %}
                    <button class="product-single__thumb" data-image="{{ image.url }}">
                        <img src="{{ image.url }}" alt="{{ product.name }}">
                    </button>
                {% endfor %}
            </div>
            {% endif %}
        </div>

        {# ===== Info & purchase ===== #}
        <div class="product-single__info reveal">
            {% if product.brand %}
                <span class="section-eyebrow">{{ product.brand.name }}</span>
            {% endif %}
            <h1 class="product-single__title">{{ product.name }}</h1>

            <div class="product-single__price">
                {% if product.is_on_sale %}
                    <span class="product-single__price--old">{{ product.regular_price }}</span>
                {% endif %}
                <span class="product-single__price--current">{{ product.price }}</span>
            </div>

            {% if product.rating %}
            <div class="product-single__rating" aria-label="التقييم">
                {{ salla_rating_stars(product.rating) }}
                <span>({{ product.rating_count }} تقييم)</span>
            </div>
            {% endif %}

            <div class="product-single__description">
                {{ product.description }}
            </div>

            {% if product.options %}
            <div class="product-single__options">
                {% for option in product.options %}
                    <div class="product-option">
                        <label class="product-option__label">{{ option.name }}</label>
                        {% component 'product.option-'~option.type with {'option': option} %}
                    </div>
                {% endfor %}
            </div>
            {% endif %}

            <div class="product-single__actions">
                <div class="quantity-input">
                    <button type="button" class="quantity-input__btn" data-action="decrease" aria-label="إنقاص الكمية">−</button>
                    <input type="number" value="1" min="1" class="quantity-input__field" id="product-quantity">
                    <button type="button" class="quantity-input__btn" data-action="increase" aria-label="زيادة الكمية">+</button>
                </div>
                <button class="btn-luxury btn-luxury--dark product-single__add-to-cart" data-product-id="{{ product.id }}">
                    أضف إلى السلة
                </button>
            </div>

            {% component 'product.policies-summary' %}
        </div>
    </div>

    {% if product.related_products %}
    <div class="product-single__related">
        <div class="section-header" style="text-align:center">
            <span class="section-eyebrow">قد يعجبك أيضًا</span>
            <h2 class="section-title">قطع مكمّلة</h2>
            <hr class="section-divider">
        </div>
        {% component 'related-products' %}
    </div>
    {% endif %}
</section>

<style>
.product-single__grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 4rem);
}
@media (max-width: 900px) {
    .product-single__grid { grid-template-columns: 1fr; }
}
.product-single__main-image {
    aspect-ratio: 4/5;
    overflow: hidden;
    background: var(--color-cream);
}
.product-single__main-image img { width: 100%; height: 100%; object-fit: cover; }
.product-single__thumbs {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.75rem;
}
.product-single__thumb {
    width: 72px;
    height: 90px;
    border: 1px solid var(--color-border);
    background: none;
    padding: 0;
    cursor: pointer;
    overflow: hidden;
}
.product-single__thumb img { width: 100%; height: 100%; object-fit: cover; }

.product-single__title {
    font-size: clamp(1.6rem, 3vw, 2.25rem);
    margin: 0.5rem 0 1rem;
}
.product-single__price { margin-bottom: 1rem; }
.product-single__price--old {
    text-decoration: line-through;
    color: var(--color-text-muted);
    margin-inline-end: 0.75rem;
    font-size: 0.95rem;
}
.product-single__price--current {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    color: var(--color-primary);
}
.product-single__description {
    line-height: 1.9;
    color: var(--color-text-muted);
    margin: 1.5rem 0;
}
.product-single__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 2rem 0;
}
.quantity-input {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
}
.quantity-input__btn {
    background: none;
    border: none;
    width: 42px;
    height: 48px;
    cursor: pointer;
    font-size: 1.1rem;
}
.quantity-input__field {
    width: 48px;
    text-align: center;
    border: none;
    border-inline: 1px solid var(--color-border);
    height: 48px;
    font-family: var(--font-body);
}
.product-single__add-to-cart {
    flex: 1;
}
.product-single__related { margin-top: 6rem; }
</style>
{% endblock %}

{% block scripts %}
    <script src="{{ 'product.js'|asset('dist/product.js') }}" defer></script>
{% endblock %}
